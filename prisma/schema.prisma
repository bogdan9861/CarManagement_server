generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum CarStatues {
  READY
  BUSY
  MAINTANCE
}

enum Role {
  ADMIN
  DRIVER
}

enum MessageType {
  INFO
  REQUEST
}

model User {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  firstName String
  lastName  String

  reports       Report[]
  notifications Notifications[]
  role          Role            @default(ADMIN)

  drivers        Driver[]
  cars           Car[]
  driverToAdmins DriverToAdmin[]
}

model Driver {
  id String @id @default(uuid())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String?

  cars Car[]

  driverToAdmins DriverToAdmin[]
}

model DriverToAdmin {
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  driverId String

  admin   User   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminId String

  @@id(name: "DriverAdminId", [driverId, adminId])
}

model Car {
  id       String     @id @default(uuid())
  name     String
  number   String
  year     String
  status   CarStatues @default(READY)
  imageUrl String
  reports  Report[]

  driver   Driver @relation(fields: [driverId], references: [id])
  driverId String

  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

model Report {
  id      String   @id @default(uuid())
  name    String
  date    DateTime @default(now())
  fileUrl String?

  reportedCar Car    @relation(fields: [carId], references: [id], onDelete: NoAction)
  carId       String

  driver        User            @relation(fields: [userId], references: [id], onDelete: NoAction)
  userId        String
  notifications Notifications[]
}

model Notifications {
  id      String @id @default(uuid())
  title   String
  message String

  reciver  User   @relation(fields: [userId], references: [id])
  userId   String
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId String

  type MessageType @default(INFO)
}
